@startuml
' Диаграмма состояний - Приложение

[*] --> Запущено

state Запущено {
    [*] --> Инициализация
    Инициализация --> ГлавноеМеню : Загрузка данных
    
    state ГлавноеМеню {
        [*] --> ОжиданиеКоманды
        
        ОжиданиеКоманды --> ДобавлениеЗаписи : Выбор "1"
        ОжиданиеКоманды --> ПросмотрЗаписей : Выбор "2"
        ОжиданиеКоманды --> Отчет : Выбор "3"
        ОжиданиеКоманды --> Статистика : Выбор "4"
        ОжиданиеКоманды --> УдалениеЗаписи : Выбор "5"
        ОжиданиеКоманды --> Редактирование : Выбор "6"
        ОжиданиеКоманды --> Поиск : Выбор "7"
        ОжиданиеКоманды --> Фильтр : Выбор "8"
        ОжиданиеКоманды --> Экспорт : Выбор "9"
        ОжиданиеКоманды --> ПутьКФайлу : Выбор "10"
        ОжиданиеКоманды --> Выход : Выбор "0"
        
        ДобавлениеЗаписи --> Сохранение : Ввод данных
        Сохранение --> ОжиданиеКоманды : Сохранено
        
        ПросмотрЗаписей --> ОжиданиеКоманды : Показано
        Отчет --> ОжиданиеКоманды : Показан
        Статистика --> ОжиданиеКоманды : Показана
        
        УдалениеЗаписи --> Сохранение : Выбор записи
        Редактирование --> Сохранение : Новые данные
        
        Поиск --> ОжиданиеКоманды : Результаты
        Фильтр --> ОжиданиеКоманды : Результаты
        Экспорт --> ОжиданиеКоманды : Экспортировано
        ПутьКФайлу --> ОжиданиеКоманды : Показан
        
        Выход --> [*] : Сохранение
    }
}

Запущено --> [*] : Завершение

note right of Инициализация
  Загрузка данных из JSON
  или создание пустого списка
end note

note right of ОжиданиеКоманды
  Основное состояние
  Ожидание выбора пользователя
end note

note right of Сохранение
  Сохранение данных в JSON
  после любого изменения
end note
@enduml